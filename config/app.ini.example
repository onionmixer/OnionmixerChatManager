; OnionmixerChatManagerQt5 — app.ini 예시 (v0.1.0)
; 이 파일을 app.ini로 복사 후 운영 환경에 맞게 수정하세요.
; 실 값을 담은 app.ini는 .gitignore로 제외됩니다.

[app]
language=ko_KR
log_level=info
auto_reconnect=true
chat_font_family=
chat_font_size=11
chat_max_messages=5000

[youtube]
enabled=false
client_id=
client_secret=
redirect_uri=http://127.0.0.1:8080/oauth2callback
auth_endpoint=https://accounts.google.com/o/oauth2/v2/auth
token_endpoint=https://oauth2.googleapis.com/token
scope=https://www.googleapis.com/auth/youtube.readonly

[chzzk]
enabled=false
client_id=
client_secret=
redirect_uri=http://127.0.0.1:8080/oauth2callback
auth_endpoint=https://chzzk.naver.com/account-interlock
token_endpoint=https://openapi.chzzk.naver.com/auth/v1/token

[broadcast]
viewer_count_position=TopLeft
window_width=400
window_height=600
transparent_bg_color=#00000000
opaque_bg_color=#FFFFFFFF

[broadchat]
enabled=true
tcp_bind=127.0.0.1
tcp_port=47123
; auth_token: 빈 값이면 인증 비활성화.
; 설정 창 General 탭 "Generate" 버튼 또는 openssl rand -hex 32 등으로 생성.
auth_token=
max_clients=10
reject_duplicate_client_id=false
duplicate_kick_target=newest
trace=false
